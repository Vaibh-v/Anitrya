generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  image       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  accounts    Account[]
  tokens      IntegrationToken[]
  memberships Membership[]
  sessions    Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id                String                  @id @default(cuid())
  name              String
  slug              String                  @unique
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  ga4Metrics        Ga4DailyMetric[]
  ga4LandingMetrics Ga4LandingPageMetric[]
  ga4Props          Ga4Property[]
  ga4SourceMetrics  Ga4SourceMediumMetric[]
  gscMetrics        GscDailyMetric[]
  gscPageMetrics    GscPageMetric[]
  gscQueryMetrics   GscQueryMetric[]
  gscSites          GscSite[]
  insights          Insight[]
  tokens            IntegrationToken[]
  memberships       Membership[]
  projects          Project[]
  syncRuns          SyncRun[]
}

model Membership {
  id          String    @id @default(cuid())
  role        Role      @default(ADMIN)
  userId      String
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model IntegrationToken {
  id           String              @id @default(cuid())
  provider     IntegrationProvider
  accessToken  String?
  refreshToken String?
  expiresAt    Int?
  scope        String?
  apiKey       String?
  workspaceId  String
  userId       String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([userId])
}

model SyncRun {
  id          String     @id @default(cuid())
  workspaceId String
  source      SyncSource
  status      SyncStatus @default(RUNNING)
  rowsSynced  Int        @default(0)
  error       String?
  metadata    Json?
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, source])
}

model Insight {
  id          String          @id @default(cuid())
  workspaceId String
  title       String
  summary     String
  evidence    Json?
  confidence  Float
  severity    InsightSeverity
  nextSteps   String
  createdAt   DateTime        @default(now())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model GscSite {
  id           String           @id @default(cuid())
  workspaceId  String
  siteUrl      String
  permission   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  metrics      GscDailyMetric[]
  pageMetrics  GscPageMetric[]
  queryMetrics GscQueryMetric[]
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@unique([workspaceId, siteUrl])
}

model GscDailyMetric {
  id          String    @id @default(cuid())
  workspaceId String
  siteId      String
  date        DateTime
  clicks      Float
  impressions Float
  ctr         Float
  position    Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  site        GscSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([siteId, date])
  @@index([workspaceId, date])
}

model GscQueryMetric {
  id          String    @id @default(cuid())
  workspaceId String
  siteId      String
  date        DateTime
  query       String
  page        String
  clicks      Float
  impressions Float
  ctr         Float
  position    Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  site        GscSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, query, page])
  @@index([workspaceId, date])
  @@index([siteId, date])
  @@index([siteId, query])
  @@index([siteId, page])
}

model GscPageMetric {
  id          String    @id @default(cuid())
  workspaceId String
  siteId      String
  date        DateTime
  page        String
  clicks      Float
  impressions Float
  ctr         Float
  position    Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  site        GscSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([siteId, date, page])
  @@index([workspaceId, date])
  @@index([siteId, date])
  @@index([siteId, page])
}

model Ga4Property {
  id             String                  @id @default(cuid())
  workspaceId    String
  propertyName   String
  displayName    String?
  accountName    String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  metrics        Ga4DailyMetric[]
  landingMetrics Ga4LandingPageMetric[]
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceMetrics  Ga4SourceMediumMetric[]
  projects       Project[]

  @@unique([workspaceId, propertyName])
}

model Ga4DailyMetric {
  id              String      @id @default(cuid())
  workspaceId     String
  propertyId      String
  date            DateTime
  users           Float
  sessions        Float
  engagedSessions Float
  engagementRate  Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  property        Ga4Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([workspaceId, date])
}

model Ga4LandingPageMetric {
  id             String      @id @default(cuid())
  workspaceId    String
  propertyId     String
  date           DateTime
  page           String
  sessions       Float
  users          Float
  conversions    Float
  engagementRate Float?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  property       Ga4Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date, page])
  @@index([workspaceId, date])
  @@index([propertyId, date])
  @@index([propertyId, page])
}

model Ga4SourceMediumMetric {
  id             String      @id @default(cuid())
  workspaceId    String
  propertyId     String
  date           DateTime
  sourceMedium   String
  sessions       Float
  users          Float
  conversions    Float
  engagementRate Float?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  property       Ga4Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  workspace      Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date, sourceMedium])
  @@index([workspaceId, date])
  @@index([propertyId, date])
  @@index([propertyId, sourceMedium])
}

model Project {
  id            String       @id @default(cuid())
  name          String
  workspaceId   String
  createdAt     DateTime     @default(now())
  ga4PropertyId String?
  gscSiteId     String?
  slug          String
  updatedAt     DateTime     @updatedAt
  ga4Property   Ga4Property? @relation(fields: [ga4PropertyId], references: [id])
  gscSite       GscSite?     @relation(fields: [gscSiteId], references: [id])
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model ga4_landing_page_daily {
  id               String    @id @default(dbgenerated("gen_random_uuid()"))
  workspace_id     String
  project_slug     String
  date             DateTime  @db.Date
  landing_page     String?
  page_path        String?
  sessions         Int?
  users            Int?
  engaged_sessions Int?
  conversions      Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([workspace_id, project_slug, date], map: "idx_ga4_landing_page_daily_workspace_project_date")
}

model ga4_source_daily {
  id               String    @id @default(dbgenerated("gen_random_uuid()"))
  workspace_id     String
  project_slug     String
  date             DateTime  @db.Date
  source           String?
  medium           String?
  sessions         Int?
  users            Int?
  engaged_sessions Int?
  conversions      Int?
  created_at       DateTime? @default(now()) @db.Timestamp(6)

  @@index([workspace_id, project_slug, date], map: "idx_ga4_source_daily_workspace_project_date")
}

model gsc_page_daily {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  workspace_id String
  project_slug String
  date         DateTime  @db.Date
  page         String?
  clicks       Int?
  impressions  Int?
  ctr          Float?
  position     Float?
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([workspace_id, project_slug, date], map: "idx_gsc_page_daily_workspace_project_date")
}

model gsc_query_daily {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  workspace_id String
  project_slug String
  date         DateTime  @db.Date
  query        String?
  clicks       Int?
  impressions  Int?
  ctr          Float?
  position     Float?
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([workspace_id, project_slug, date], map: "idx_gsc_query_daily_workspace_project_date")
}

model intelligence_history {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspace_id       String
  project_slug       String
  category           String
  title              String
  summary            String
  confidence         String
  score              Int       @default(0)
  evidence_json      Json      @default("[]")
  actions_json       Json      @default("[]")
  source_window_from DateTime? @db.Date
  source_window_to   DateTime? @db.Date
  fingerprint        String    @unique(map: "idx_intelligence_history_fingerprint")
  created_at         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([workspace_id, project_slug, created_at(sort: Desc)], map: "idx_intelligence_history_workspace_slug_created")
}

model recommendation_outcomes {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspace_id         String
  project_slug         String
  hypothesis_title     String
  recommendation_title String
  outcome_status       String
  outcome_note         String   @default("")
  impact_delta         Int      @default(0)
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  @@index([workspace_id, project_slug, created_at(sort: Desc)], map: "idx_recommendation_outcomes_workspace_slug_created")
}

enum Role {
  ADMIN
  EDITOR
  ANALYST
  VIEWER
}

enum IntegrationProvider {
  GOOGLE_GSC
  GOOGLE_GA4
  SEMRUSH
  AHREFS
  BIRDEYE
  GOOGLE_ADS
  GOOGLE_GBP
  GOOGLE_TRENDS
  META_AD_LIBRARY
}

enum SyncSource {
  GOOGLE_GSC
  GOOGLE_GA4
  SEMRUSH
  AHREFS
  BIRDEYE
  GOOGLE_ADS
  GOOGLE_GBP
  GOOGLE_TRENDS
  META_AD_LIBRARY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

enum InsightSeverity {
  LOW
  MEDIUM
  HIGH
}
